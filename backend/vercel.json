{
  "rewrites": [
    {
      "source": "/frontend/(.*)",
      "destination": "https://sub-store.vercel.app/frontend/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}